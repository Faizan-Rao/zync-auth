# Copy to .env and adjust.
# Chain 31337 + deploy:local → token is usually at the default address below.

# --- Blockchain ---
CHAIN_ID=31337
RPC_URL=http://127.0.0.1:8545
ZYNC_TOKEN_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# --- Server ---
PORT=3001
BIND_HOST=0.0.0.0

# --- Optional ---
